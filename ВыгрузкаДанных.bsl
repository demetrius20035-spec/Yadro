// ============================================================
// Обработка: УниверсальнаяВыгрузкаДанных
// Назначение: универсальная (для любой конфигурации) выгрузка ДАННЫХ
//             объектов, описанных в metadata_selected_cleaned.json:
//   Режим 1 (XML):     множество XML-файлов по контракту из папки schemas
//                      (XSD, сгенерированные generate_xml_schema.py).
//                      Один объект -> серия файлов по РазмерПорции записей.
//   Режим 2 (MariaDB): REPLACE INTO в таблицы, созданные по schema.sql
//                      (сгенерирован generate_mariadb_schema.py). Имена
//                      таблиц/колонок формируются ПО ТЕМ ЖЕ ПРАВИЛАМ.
//
// Структуру выгрузки задаёт ИМЕННО JSON (после чистки в MetadataEditor.py):
// выгружаются только перечисленные в нём объекты и только их поля.
//
// Поддерживаемые типы объектов: Справочник, Документ, РегистрНакопления
// (ровно те, что обрабатывают генераторы схем). Остальные пропускаются
// с записью в журнал.
//
// ОТБОРЫ / ОГРАНИЧЕНИЯ ОБЪЁМА:
//   Документы:        ДатаНачала/ДатаОкончания (по полю Дата),
//                     Организация (если есть реквизит "Организация"),
//                     ТолькоПроведенные.
//   РегистрыНакопления: ДатаНачала/ДатаОкончания (по полю Период),
//                     Организация (если есть измерение "Организация").
//   Справочники:      выгружаются полностью; действует флаг
//                     БезПомеченныхНаУдаление.
//   Все объекты:      ЛимитЗаписейНаОбъект (0 = без лимита) — страховка
//                     от колоссальных объёмов; РазмерПорции — размер
//                     одного XML-файла / одного пакета REPLACE INTO;
//                     СписокОбъектов — необязательный отбор по объектам
//                     (полные имена через запятую) поверх JSON.
//
// ТРЕБОВАНИЯ К ФОРМЕ ОБРАБОТКИ (создать вручную, как у metadata.bsl):
//   Реквизиты формы:
//     ФайлМетаданных          (Строка)  - путь к metadata_selected_cleaned.json (на сервере)
//     КаталогСхем             (Строка)  - путь к папке schemas с *.xsd (необязательно;
//                                         если заполнен — объекты без схемы не выгружаются)
//     КаталогВыгрузки         (Строка)  - каталог для XML-файлов (на сервере)
//     ФайлСхемыSQL            (Строка)  - путь к schema.sql (для команды загрузки схемы)
//     ИмяБазыMariaDB          (Строка)  - имя базы в MariaDB
//     СписокОбъектов          (Строка)  - отбор по объектам, через запятую (пусто = все из JSON)
//     ДатаНачала              (Дата)
//     ДатаОкончания           (Дата)
//     Организация             (СправочникСсылка.Организации либо Произвольный)
//     ТолькоПроведенные       (Булево)
//     БезПомеченныхНаУдаление (Булево)
//     РазмерПорции            (Число)  - по умолчанию 1000
//     ЛимитЗаписейНаОбъект    (Число)  - 0 = без лимита
//     ЖурналВыгрузки          (Строка, многострочная) - протокол выполнения
//   Команды формы (привязать к процедурам ниже):
//     ВыгрузитьВXML, ВыгрузитьВMariaDB, ЗагрузитьСхемуВБазуДанных
//
// ЗАВИСИМОСТИ: общий модуль РаботаСMariaDB (файл МодульРаботыСMariaDB.bsl)
//   — используется только в режиме MariaDB.
//
// ИЗВЕСТНЫЕ ОГРАНИЧЕНИЯ:
//   * ХранилищеЗначения не выгружается (в XML элемент опускается, в SQL — NULL).
//   * Пустая дата 1С (01.01.0001) выгружается как отсутствие значения / NULL.
//   * Ссылки выгружаются как Тип+GUID (отложенное разрешение — по контракту схем).
// ============================================================

// ============================================================
// КЛИЕНТСКАЯ ЧАСТЬ
// ============================================================

&НаКлиенте
Процедура ВыгрузитьВXML(Команда)
	Если НЕ ПроверитьОбщиеПоля() Тогда
		Возврат;
	КонецЕсли;
	Если ПустаяСтрока(КаталогВыгрузки) Тогда
		ПоказатьПредупреждение(, "Укажите каталог выгрузки XML-файлов.");
		Возврат;
	КонецЕсли;
	ЖурналВыгрузки = "";
	ВыполнитьВыгрузкуНаСервере("XML");
КонецПроцедуры

&НаКлиенте
Процедура ВыгрузитьВMariaDB(Команда)
	Если НЕ ПроверитьОбщиеПоля() Тогда
		Возврат;
	КонецЕсли;
	Если ПустаяСтрока(ИмяБазыMariaDB) Тогда
		ПоказатьПредупреждение(, "Укажите имя базы данных MariaDB.");
		Возврат;
	КонецЕсли;
	ЖурналВыгрузки = "";
	ВыполнитьВыгрузкуНаСервере("SQL");
КонецПроцедуры

&НаКлиенте
Процедура ЗагрузитьСхемуВБазуДанных(Команда)
	Если ПустаяСтрока(ФайлСхемыSQL) Тогда
		ПоказатьПредупреждение(, "Укажите путь к файлу schema.sql.");
		Возврат;
	КонецЕсли;
	Если ПустаяСтрока(ИмяБазыMariaDB) Тогда
		ПоказатьПредупреждение(, "Укажите имя базы данных MariaDB.");
		Возврат;
	КонецЕсли;
	ЖурналВыгрузки = "";
	ЗагрузитьСхемуSQLНаСервере();
КонецПроцедуры

&НаКлиенте
Функция ПроверитьОбщиеПоля()
	Если ПустаяСтрока(ФайлМетаданных) Тогда
		ПоказатьПредупреждение(, "Укажите путь к файлу metadata_selected_cleaned.json.");
		Возврат Ложь;
	КонецЕсли;
	Возврат Истина;
КонецФункции

// ============================================================
// СЕРВЕРНАЯ ЧАСТЬ — точки входа
// ============================================================

&НаСервере
Процедура ВыполнитьВыгрузкуНаСервере(Режим)

	Журнал = Новый Массив;
	Журнал.Добавить("=== Выгрузка данных, режим: " + ?(Режим = "XML", "XML-файлы", "MariaDB") + " ===");
	Журнал.Добавить("Начало: " + Строка(ТекущаяДатаСеанса()));

	Попытка
		Конфиг = ЗагрузитьКонфигурациюВыгрузки(ФайлМетаданных);
	Исключение
		Журнал.Добавить("ОШИБКА чтения метаданных: " + ОписаниеОшибки());
		ЗавершитьЖурнал(Журнал);
		Возврат;
	КонецПопытки;

	Параметры = ПодготовитьПараметрыВыгрузки(Режим, Конфиг);
	ОтборОбъектов = МножествоВыбранныхОбъектов();

	ВсегоОбъектов = 0;
	ВсегоЗаписей  = 0;

	Для Каждого Объект Из Конфиг.Объекты Цикл

		Если ОтборОбъектов <> Неопределено
			И ОтборОбъектов[ВРег(Объект.ПолноеИмя)] = Неопределено Тогда
			Продолжить;
		КонецЕсли;

		Если Объект.Тип <> "Справочник" И Объект.Тип <> "Документ"
			И Объект.Тип <> "РегистрНакопления" Тогда
			Журнал.Добавить("ПРОПУЩЕН (неподдерживаемый тип): " + Объект.ПолноеИмя);
			Продолжить;
		КонецЕсли;

		// В режиме XML выгружаем строго по контракту: схема обязана существовать
		Если Режим = "XML" И ЗначениеЗаполнено(КаталогСхем)
			И НЕ СхемаОбъектаСуществует(Объект) Тогда
			Журнал.Добавить("ПРОПУЩЕН (нет XSD-схемы в каталоге схем): " + Объект.ПолноеИмя);
			Продолжить;
		КонецЕсли;

		Попытка
			Количество = ВыгрузитьОбъект(Объект, Параметры);
			ВсегоОбъектов = ВсегоОбъектов + 1;
			ВсегоЗаписей  = ВсегоЗаписей + Количество;
			Журнал.Добавить("OK " + Объект.ПолноеИмя + ": записей " + Формат(Количество, "ЧГ=0"));
		Исключение
			ТекстОшибки = ОписаниеОшибки();
			Журнал.Добавить("ОШИБКА " + Объект.ПолноеИмя + ": " + ТекстОшибки);
			ЗаписьЖурналаРегистрации("УниверсальнаяВыгрузкаДанных",
				УровеньЖурналаРегистрации.Ошибка, , ,
				Объект.ПолноеИмя + ": " + ТекстОшибки);
		КонецПопытки;

	КонецЦикла;

	Журнал.Добавить("=== Итог: объектов " + Формат(ВсегоОбъектов, "ЧГ=0")
		+ ", записей " + Формат(ВсегоЗаписей, "ЧГ=0") + " ===");
	ЗавершитьЖурнал(Журнал);

КонецПроцедуры

&НаСервере
Процедура ЗавершитьЖурнал(Журнал)
	Журнал.Добавить("Окончание: " + Строка(ТекущаяДатаСеанса()));
	ЖурналВыгрузки = СтрСоединить(Журнал, Символы.ПС);
КонецПроцедуры

// ============================================================
// Загрузка конфигурации выгрузки (metadata_selected_cleaned.json)
// ============================================================

&НаСервере
Функция ЗагрузитьКонфигурациюВыгрузки(ПутьКФайлу)
	Файл = Новый Файл(ПутьКФайлу);
	Если НЕ Файл.Существует() Тогда
		ВызватьИсключение "Файл метаданных не найден: " + ПутьКФайлу;
	КонецЕсли;

	Чтение = Новый ЧтениеJSON;
	Чтение.ОткрытьФайл(ПутьКФайлу, "UTF-8");
	Конфиг = ПрочитатьJSON(Чтение);
	Чтение.Закрыть();

	Если ТипЗнч(Конфиг) <> Тип("Структура") ИЛИ НЕ Конфиг.Свойство("Объекты") Тогда
		ВызватьИсключение "Некорректный формат файла метаданных (нет коллекции Объекты).";
	КонецЕсли;
	Возврат Конфиг;
КонецФункции

&НаСервере
Функция ПодготовитьПараметрыВыгрузки(Режим, Конфиг)
	Параметры = Новый Структура;
	Параметры.Вставить("Режим",            Режим);
	Параметры.Вставить("РазмерПорции",     ?(РазмерПорции > 0, РазмерПорции, 1000));
	Параметры.Вставить("Лимит",            ЛимитЗаписейНаОбъект);
	Параметры.Вставить("ДатаНачала",       ДатаНачала);
	Параметры.Вставить("ДатаОкончания",    ?(ЗначениеЗаполнено(ДатаОкончания), КонецДня(ДатаОкончания), ДатаОкончания));
	Параметры.Вставить("Организация",      Организация);
	Параметры.Вставить("ТолькоПроведенные", ТолькоПроведенные);
	Параметры.Вставить("БезПомеченных",    БезПомеченныхНаУдаление);
	Параметры.Вставить("КаталогВыгрузки",  КаталогВыгрузки);
	Параметры.Вставить("ИмяБазы",          ИмяБазыMariaDB);
	ИмяКонфигурации = "";
	ВерсияКонфигурацииJSON = "";
	Конфиг.Свойство("ИмяКонфигурации", ИмяКонфигурации);
	Конфиг.Свойство("ВерсияКонфигурации", ВерсияКонфигурацииJSON);
	Параметры.Вставить("Конфигурация",     ИмяКонфигурации);
	Параметры.Вставить("ВерсияКонфигурации", ВерсияКонфигурацииJSON);
	Параметры.Вставить("ВерсияФормата",    "1.0");
	Параметры.Вставить("ДатаВыгрузки",     ТекущаяДатаСеанса());
	Возврат Параметры;
КонецФункции

// Отбор по объектам поверх JSON: полные имена через запятую.
// Возвращает Соответствие (ВРег ПолноеИмя -> Истина) или Неопределено = все.
&НаСервере
Функция МножествоВыбранныхОбъектов()
	Если ПустаяСтрока(СписокОбъектов) Тогда
		Возврат Неопределено;
	КонецЕсли;
	Множество = Новый Соответствие;
	Для Каждого Часть Из СтрРазделить(СписокОбъектов, ",", Ложь) Цикл
		Множество.Вставить(ВРег(СокрЛП(Часть)), Истина);
	КонецЦикла;
	Возврат Множество;
КонецФункции

&НаСервере
Функция СхемаОбъектаСуществует(Объект)
	ИмяСхемы = СтрЗаменить(Объект.ПолноеИмя, ".", "_") + ".xsd";
	ФайлСхемы = Новый Файл(ДобавитьРазделитель(КаталогСхем) + ИмяСхемы);
	Возврат ФайлСхемы.Существует();
КонецФункции

// ============================================================
// Описание полей объекта по JSON
// ============================================================

// Для каждого поля строим плоское описание:
//   Имя, Составной, Ссылочный, ИмяТипа, ЕстьПримитив, ТолькоДата, Хранилище
&НаСервере
Функция ОписаниеПоляИзJSON(ПолеJSON)

	Описание = Новый Структура;
	Описание.Вставить("Имя", ПолеJSON.Имя);
	Описание.Вставить("Составной", Ложь);
	Описание.Вставить("Ссылочный", Ложь);
	Описание.Вставить("ИмяТипа", "");
	Описание.Вставить("ЕстьПримитив", Ложь);
	Описание.Вставить("ТолькоДата", Ложь);
	Описание.Вставить("Хранилище", Ложь);

	ТипПоля = Неопределено;
	Если НЕ ПолеJSON.Свойство("Тип", ТипПоля) ИЛИ ТипПоля = Неопределено Тогда
		// Нет описания типа — считаем составным (неразрешённая ссылка)
		Описание.Составной = Истина;
		Возврат Описание;
	КонецЕсли;

	Типы = ТипПоля.Типы;
	// Пустой список типов — неразрешённая ссылка, трактуем как составной
	// (ровно так же поступают оба генератора схем).
	Описание.Составной = ТипПоля.Составной ИЛИ Типы.Количество() = 0;

	Если Описание.Составной Тогда
		Для Каждого Т Из Типы Цикл
			Если НЕ Т.Ссылочный Тогда
				Описание.ЕстьПримитив = Истина;
			КонецЕсли;
		КонецЦикла;
		Возврат Описание;
	КонецЕсли;

	Т1 = Типы[0];
	Описание.Ссылочный = Т1.Ссылочный;
	Описание.ИмяТипа = Т1.ИмяТипа;
	Если НЕ Описание.Ссылочный Тогда
		Если Т1.ИмяТипа = "Дата" Тогда
			ЧастиДаты = "";
			Т1.Свойство("ЧастиДаты", ЧастиДаты);
			Описание.ТолькоДата = (ЧастиДаты = "Дата");
		ИначеЕсли Т1.ИмяТипа = "ХранилищеЗначения" ИЛИ Т1.ИмяТипа = "Хранилище значения" Тогда
			Описание.Хранилище = Истина;
		КонецЕсли;
	КонецЕсли;

	Возврат Описание;

КонецФункции

// Описание всех полей объекта.
// Возвращает структуру:
//   Поля    - массив описаний полей шапки (стандартные + реквизиты,
//             для регистров: измерения + ресурсы + реквизиты);
//   ТабличныеЧасти - массив структур (Имя, Поля) — только для ссылочных.
&НаСервере
Функция ОписаниеПолейОбъекта(Объект)

	Результат = Новый Структура;
	Поля = Новый Массив;
	ИменаПолей = Новый Соответствие;

	Если Объект.Тип = "РегистрНакопления" Тогда
		ДобавитьПоляКоллекции(Поля, ИменаПолей, Объект, "Измерения");
		ДобавитьПоляКоллекции(Поля, ИменаПолей, Объект, "Ресурсы");
		ДобавитьПоляКоллекции(Поля, ИменаПолей, Объект, "Реквизиты");
	Иначе
		ДобавитьПоляКоллекции(Поля, ИменаПолей, Объект, "СтандартныеРеквизиты");
		ДобавитьПоляКоллекции(Поля, ИменаПолей, Объект, "Реквизиты");
	КонецЕсли;

	Результат.Вставить("Поля", Поля);

	ТабличныеЧасти = Новый Массив;
	КоллекцияТЧ = Неопределено;
	Если Объект.Свойство("ТабличныеЧасти", КоллекцияТЧ) И КоллекцияТЧ <> Неопределено Тогда
		Для Каждого ТЧ Из КоллекцияТЧ Цикл
			ПоляТЧ = Новый Массив;
			ИменаТЧ = Новый Соответствие;
			Для Каждого ПолеJSON Из ТЧ.Реквизиты Цикл
				ДобавитьОдноПоле(ПоляТЧ, ИменаТЧ, ПолеJSON);
			КонецЦикла;
			ОписаниеТЧ = Новый Структура("Имя, Поля", ТЧ.Имя, ПоляТЧ);
			ТабличныеЧасти.Добавить(ОписаниеТЧ);
		КонецЦикла;
	КонецЕсли;
	Результат.Вставить("ТабличныеЧасти", ТабличныеЧасти);

	Возврат Результат;

КонецФункции

&НаСервере
Процедура ДобавитьПоляКоллекции(Поля, ИменаПолей, Объект, ИмяКоллекции)
	Коллекция = Неопределено;
	Если НЕ Объект.Свойство(ИмяКоллекции, Коллекция) ИЛИ Коллекция = Неопределено Тогда
		Возврат;
	КонецЕсли;
	Для Каждого ПолеJSON Из Коллекция Цикл
		ДобавитьОдноПоле(Поля, ИменаПолей, ПолеJSON);
	КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ДобавитьОдноПоле(Поля, ИменаПолей, ПолеJSON)
	// Дубликаты имён (стандартный + одноимённый реквизит) пропускаем:
	// в запросе 1С нельзя выбрать два поля с одним псевдонимом
	Если ИменаПолей[ВРег(ПолеJSON.Имя)] <> Неопределено Тогда
		Возврат;
	КонецЕсли;
	ИменаПолей.Вставить(ВРег(ПолеJSON.Имя), Истина);
	Поля.Добавить(ОписаниеПоляИзJSON(ПолеJSON));
КонецПроцедуры

&НаСервере
Функция ЕстьПоле(Поля, ИмяПоля)
	Для Каждого Поле Из Поля Цикл
		Если ВРег(Поле.Имя) = ВРег(ИмяПоля) Тогда
			Возврат Истина;
		КонецЕсли;
	КонецЦикла;
	Возврат Ложь;
КонецФункции

// ============================================================
// ВЫГРУЗКА ОБЪЕКТА: порционная выборка
// ============================================================

&НаСервере
Функция ВыгрузитьОбъект(Объект, Параметры)
	ОписаниеПолей = ОписаниеПолейОбъекта(Объект);
	Если Объект.Тип = "РегистрНакопления" Тогда
		Возврат ВыгрузитьРегистрНакопления(Объект, ОписаниеПолей, Параметры);
	Иначе
		Возврат ВыгрузитьСсылочныйОбъект(Объект, ОписаниеПолей, Параметры);
	КонецЕсли;
КонецФункции

// --- Справочники и документы --------------------------------

&НаСервере
Функция ВыгрузитьСсылочныйОбъект(Объект, ОписаниеПолей, Параметры)

	Если НЕ ЕстьПоле(ОписаниеПолей.Поля, "Ссылка") Тогда
		ВызватьИсключение "В описании объекта нет стандартного реквизита ""Ссылка"" — "
			+ "он обязателен (не удаляйте его в MetadataEditor).";
	КонецЕсли;

	Запрос = Новый Запрос(ТекстЗапросаШапки(Объект, ОписаниеПолей, Параметры));
	УстановитьПараметрыОтбора(Запрос, Параметры);
	Выборка = Запрос.Выполнить().Выбрать();

	Контекст = Новый Структура("НомерПорции, ВсегоЗаписей", 0, 0);
	Порция = Новый Массив;

	Пока Выборка.Следующий() Цикл
		Порция.Добавить(ПрочитатьЗаписьВыборки(Выборка, ОписаниеПолей.Поля));
		Если Порция.Количество() >= Параметры.РазмерПорции Тогда
			ОбработатьПорциюСсылочного(Объект, ОписаниеПолей, Порция, Параметры, Контекст);
			Порция = Новый Массив;
		КонецЕсли;
	КонецЦикла;

	Если Порция.Количество() > 0 Тогда
		ОбработатьПорциюСсылочного(Объект, ОписаниеПолей, Порция, Параметры, Контекст);
	КонецЕсли;

	Возврат Контекст.ВсегоЗаписей;

КонецФункции

&НаСервере
Функция ТекстЗапросаШапки(Объект, ОписаниеПолей, Параметры)

	СписокПолей = "";
	Для Каждого Поле Из ОписаниеПолей.Поля Цикл
		СписокПолей = СписокПолей + ?(СписокПолей = "", "", "," + Символы.ПС)
			+ "	Т." + Поле.Имя + " КАК " + Поле.Имя;
	КонецЦикла;

	Текст = "ВЫБРАТЬ "
		+ ?(Параметры.Лимит > 0, "ПЕРВЫЕ " + Формат(Параметры.Лимит, "ЧГ=0") + " ", "")
		+ Символы.ПС + СписокПолей + Символы.ПС
		+ "ИЗ " + Объект.ПолноеИмя + " КАК Т";

	Условия = Новый Массив;
	Если Объект.Тип = "Документ" Тогда
		Если ЗначениеЗаполнено(Параметры.ДатаНачала) Тогда
			Условия.Добавить("Т.Дата >= &ДатаНачала");
		КонецЕсли;
		Если ЗначениеЗаполнено(Параметры.ДатаОкончания) Тогда
			Условия.Добавить("Т.Дата <= &ДатаОкончания");
		КонецЕсли;
		Если Параметры.ТолькоПроведенные И ЕстьПоле(ОписаниеПолей.Поля, "Проведен") Тогда
			Условия.Добавить("Т.Проведен");
		КонецЕсли;
		Если ЗначениеЗаполнено(Параметры.Организация) И ЕстьПоле(ОписаниеПолей.Поля, "Организация") Тогда
			Условия.Добавить("Т.Организация = &Организация");
		КонецЕсли;
	ИначеЕсли Объект.Тип = "Справочник" Тогда
		Если Параметры.БезПомеченных И ЕстьПоле(ОписаниеПолей.Поля, "ПометкаУдаления") Тогда
			Условия.Добавить("НЕ Т.ПометкаУдаления");
		КонецЕсли;
	КонецЕсли;

	Если Условия.Количество() > 0 Тогда
		Текст = Текст + Символы.ПС + "ГДЕ " + СтрСоединить(Условия, Символы.ПС + "	И ");
	КонецЕсли;

	Если Объект.Тип = "Документ" Тогда
		Текст = Текст + Символы.ПС + "УПОРЯДОЧИТЬ ПО Т.Дата";
	КонецЕсли;

	Возврат Текст;

КонецФункции

&НаСервере
Процедура УстановитьПараметрыОтбора(Запрос, Параметры)
	Запрос.УстановитьПараметр("ДатаНачала",    Параметры.ДатаНачала);
	Запрос.УстановитьПараметр("ДатаОкончания", Параметры.ДатаОкончания);
	Запрос.УстановитьПараметр("Организация",   Параметры.Организация);
КонецПроцедуры

&НаСервере
Функция ПрочитатьЗаписьВыборки(Выборка, Поля)
	Запись = Новый Соответствие;
	Для Каждого Поле Из Поля Цикл
		Запись.Вставить(Поле.Имя, Выборка[Поле.Имя]);
	КонецЦикла;
	Возврат Запись;
КонецФункции

// Дочитывает табличные части порции и передаёт порцию писателю (XML/SQL)
&НаСервере
Процедура ОбработатьПорциюСсылочного(Объект, ОписаниеПолей, Порция, Параметры, Контекст)

	// Ссылки записей порции — для выборки строк ТЧ
	Ссылки = Новый Массив;
	Для Каждого Запись Из Порция Цикл
		Ссылки.Добавить(Запись["Ссылка"]);
	КонецЦикла;

	// ИмяТЧ -> Соответствие (Ссылка -> Массив строк)
	ДанныеТЧ = Новый Соответствие;
	Для Каждого ТЧ Из ОписаниеПолей.ТабличныеЧасти Цикл
		ДанныеТЧ.Вставить(ТЧ.Имя, ПрочитатьТабличнуюЧасть(Объект, ТЧ, Ссылки));
	КонецЦикла;

	Контекст.НомерПорции = Контекст.НомерПорции + 1;
	Контекст.ВсегоЗаписей = Контекст.ВсегоЗаписей + Порция.Количество();

	Если Параметры.Режим = "XML" Тогда
		ЗаписатьПорциюСсылочногоXML(Объект, ОписаниеПолей, Порция, ДанныеТЧ, Параметры, Контекст);
	Иначе
		ЗаписатьПорциюСсылочногоSQL(Объект, ОписаниеПолей, Порция, ДанныеТЧ, Параметры);
	КонецЕсли;

КонецПроцедуры

&НаСервере
Функция ПрочитатьТабличнуюЧасть(Объект, ОписаниеТЧ, Ссылки)

	СписокПолей = "";
	Для Каждого Поле Из ОписаниеТЧ.Поля Цикл
		СписокПолей = СписокПолей + "," + Символы.ПС + "	ТЧ." + Поле.Имя + " КАК " + Поле.Имя;
	КонецЦикла;

	Текст = "ВЫБРАТЬ" + Символы.ПС
		+ "	ТЧ.Ссылка КАК Ссылка," + Символы.ПС
		+ "	ТЧ.НомерСтроки КАК НомерСтроки"
		+ СписокПолей + Символы.ПС
		+ "ИЗ " + Объект.ПолноеИмя + "." + ОписаниеТЧ.Имя + " КАК ТЧ" + Символы.ПС
		+ "ГДЕ ТЧ.Ссылка В(&Ссылки)" + Символы.ПС
		+ "УПОРЯДОЧИТЬ ПО ТЧ.Ссылка, ТЧ.НомерСтроки";

	Запрос = Новый Запрос(Текст);
	Запрос.УстановитьПараметр("Ссылки", Ссылки);
	Выборка = Запрос.Выполнить().Выбрать();

	Результат = Новый Соответствие; // Ссылка -> Массив строк
	Пока Выборка.Следующий() Цикл
		Строки = Результат[Выборка.Ссылка];
		Если Строки = Неопределено Тогда
			Строки = Новый Массив;
			Результат.Вставить(Выборка.Ссылка, Строки);
		КонецЕсли;
		СтрокаТЧ = ПрочитатьЗаписьВыборки(Выборка, ОписаниеТЧ.Поля);
		СтрокаТЧ.Вставить("НомерСтроки", Выборка.НомерСтроки);
		Строки.Добавить(СтрокаТЧ);
	КонецЦикла;

	Возврат Результат;

КонецФункции

// --- Регистры накопления ------------------------------------

&НаСервере
Функция ВыгрузитьРегистрНакопления(Объект, ОписаниеПолей, Параметры)

	ЭтоОстатки = ВидРегистраОбъекта(Объект) = "Остатки";

	СписокПолей = "	Т.Период КАК Период," + Символы.ПС
		+ "	Т.Регистратор КАК Регистратор," + Символы.ПС
		+ "	Т.НомерСтроки КАК НомерСтроки," + Символы.ПС
		+ "	Т.Активность КАК Активность";
	Если ЭтоОстатки Тогда
		СписокПолей = СписокПолей + "," + Символы.ПС + "	Т.ВидДвижения КАК ВидДвижения";
	КонецЕсли;
	Для Каждого Поле Из ОписаниеПолей.Поля Цикл
		СписокПолей = СписокПолей + "," + Символы.ПС + "	Т." + Поле.Имя + " КАК " + Поле.Имя;
	КонецЦикла;

	Текст = "ВЫБРАТЬ "
		+ ?(Параметры.Лимит > 0, "ПЕРВЫЕ " + Формат(Параметры.Лимит, "ЧГ=0") + " ", "")
		+ Символы.ПС + СписокПолей + Символы.ПС
		+ "ИЗ " + Объект.ПолноеИмя + " КАК Т";

	Условия = Новый Массив;
	Если ЗначениеЗаполнено(Параметры.ДатаНачала) Тогда
		Условия.Добавить("Т.Период >= &ДатаНачала");
	КонецЕсли;
	Если ЗначениеЗаполнено(Параметры.ДатаОкончания) Тогда
		Условия.Добавить("Т.Период <= &ДатаОкончания");
	КонецЕсли;
	Если ЗначениеЗаполнено(Параметры.Организация) И ЕстьПоле(ОписаниеПолей.Поля, "Организация") Тогда
		Условия.Добавить("Т.Организация = &Организация");
	КонецЕсли;
	Если Условия.Количество() > 0 Тогда
		Текст = Текст + Символы.ПС + "ГДЕ " + СтрСоединить(Условия, Символы.ПС + "	И ");
	КонецЕсли;
	Текст = Текст + Символы.ПС + "УПОРЯДОЧИТЬ ПО Т.Период";

	Запрос = Новый Запрос(Текст);
	УстановитьПараметрыОтбора(Запрос, Параметры);
	Выборка = Запрос.Выполнить().Выбрать();

	Контекст = Новый Структура("НомерПорции, ВсегоЗаписей", 0, 0);
	Порция = Новый Массив;

	Пока Выборка.Следующий() Цикл
		Движение = ПрочитатьЗаписьВыборки(Выборка, ОписаниеПолей.Поля);
		Движение.Вставить("Период",       Выборка.Период);
		Движение.Вставить("Регистратор",  Выборка.Регистратор);
		Движение.Вставить("НомерСтроки",  Выборка.НомерСтроки);
		Движение.Вставить("Активность",   Выборка.Активность);
		Если ЭтоОстатки Тогда
			Движение.Вставить("ВидДвижения", Выборка.ВидДвижения);
		КонецЕсли;
		Порция.Добавить(Движение);
		Если Порция.Количество() >= Параметры.РазмерПорции Тогда
			ОбработатьПорциюРегистра(Объект, ОписаниеПолей, Порция, Параметры, Контекст, ЭтоОстатки);
			Порция = Новый Массив;
		КонецЕсли;
	КонецЦикла;

	Если Порция.Количество() > 0 Тогда
		ОбработатьПорциюРегистра(Объект, ОписаниеПолей, Порция, Параметры, Контекст, ЭтоОстатки);
	КонецЕсли;

	Возврат Контекст.ВсегоЗаписей;

КонецФункции

&НаСервере
Функция ВидРегистраОбъекта(Объект)
	ВидРегистра = "Обороты";
	Объект.Свойство("ВидРегистра", ВидРегистра);
	Возврат ВидРегистра;
КонецФункции

&НаСервере
Процедура ОбработатьПорциюРегистра(Объект, ОписаниеПолей, Порция, Параметры, Контекст, ЭтоОстатки)
	Контекст.НомерПорции = Контекст.НомерПорции + 1;
	Контекст.ВсегоЗаписей = Контекст.ВсегоЗаписей + Порция.Количество();
	Если Параметры.Режим = "XML" Тогда
		ЗаписатьПорциюРегистраXML(Объект, ОписаниеПолей, Порция, Параметры, Контекст, ЭтоОстатки);
	Иначе
		ЗаписатьПорциюРегистраSQL(Объект, ОписаниеПолей, Порция, Параметры, ЭтоОстатки);
	КонецЕсли;
КонецПроцедуры

// ============================================================
// ПИСАТЕЛЬ XML (контракт — XSD из папки schemas)
// ============================================================

&НаСервере
Функция ИмяФайлаПорцииXML(Объект, Параметры, Контекст)
	Возврат ДобавитьРазделитель(Параметры.КаталогВыгрузки)
		+ СтрЗаменить(Объект.ПолноеИмя, ".", "_")
		+ "_" + Формат(Контекст.НомерПорции, "ЧЦ=5; ЧВН=; ЧГ=0") + ".xml";
КонецФункции

&НаСервере
Функция НачатьФайлВыгрузкиXML(Объект, Параметры, Контекст)
	Запись = Новый ЗаписьXML;
	Запись.ОткрытьФайл(ИмяФайлаПорцииXML(Объект, Параметры, Контекст), "UTF-8");
	Запись.ЗаписатьОбъявлениеXML();
	Запись.ЗаписатьНачалоЭлемента("Выгрузка");
	Запись.ЗаписатьАтрибут("Конфигурация",        Строка(Параметры.Конфигурация));
	Запись.ЗаписатьАтрибут("ВерсияКонфигурации",  Строка(Параметры.ВерсияКонфигурации));
	Запись.ЗаписатьАтрибут("Объект",              Объект.ПолноеИмя);
	Запись.ЗаписатьАтрибут("ВерсияФормата",       Параметры.ВерсияФормата);
	Запись.ЗаписатьАтрибут("ДатаВыгрузки",        XMLСтрока(Параметры.ДатаВыгрузки));
	Возврат Запись;
КонецФункции

&НаСервере
Процедура ЗаписатьПорциюСсылочногоXML(Объект, ОписаниеПолей, Порция, ДанныеТЧ, Параметры, Контекст)

	Запись = НачатьФайлВыгрузкиXML(Объект, Параметры, Контекст);

	Для Каждого ЗаписьДанных Из Порция Цикл
		Запись.ЗаписатьНачалоЭлемента("Запись");

		Для Каждого Поле Из ОписаниеПолей.Поля Цикл
			ЗаписатьПолеXML(Запись, Поле, ЗаписьДанных[Поле.Имя]);
		КонецЦикла;

		Для Каждого ТЧ Из ОписаниеПолей.ТабличныеЧасти Цикл
			СтрокиТЧ = ДанныеТЧ[ТЧ.Имя][ЗаписьДанных["Ссылка"]];
			Если СтрокиТЧ = Неопределено ИЛИ СтрокиТЧ.Количество() = 0 Тогда
				Продолжить;
			КонецЕсли;
			Запись.ЗаписатьНачалоЭлемента("ТабличнаяЧасть_" + ТЧ.Имя);
			Для Каждого СтрокаТЧ Из СтрокиТЧ Цикл
				Запись.ЗаписатьНачалоЭлемента("Строка");
				Запись.ЗаписатьАтрибут("НомерСтроки", Формат(СтрокаТЧ["НомерСтроки"], "ЧГ=0"));
				Для Каждого Поле Из ТЧ.Поля Цикл
					ЗаписатьПолеXML(Запись, Поле, СтрокаТЧ[Поле.Имя]);
				КонецЦикла;
				Запись.ЗаписатьКонецЭлемента(); // Строка
			КонецЦикла;
			Запись.ЗаписатьКонецЭлемента(); // ТабличнаяЧасть_*
		КонецЦикла;

		Запись.ЗаписатьКонецЭлемента(); // Запись
	КонецЦикла;

	Запись.ЗаписатьКонецЭлемента(); // Выгрузка
	Запись.Закрыть();

КонецПроцедуры

&НаСервере
Процедура ЗаписатьПорциюРегистраXML(Объект, ОписаниеПолей, Порция, Параметры, Контекст, ЭтоОстатки)

	Запись = НачатьФайлВыгрузкиXML(Объект, Параметры, Контекст);

	Для Каждого Движение Из Порция Цикл
		Запись.ЗаписатьНачалоЭлемента("Движение");
		Запись.ЗаписатьАтрибут("НомерСтроки", Формат(Движение["НомерСтроки"], "ЧГ=0"));

		Запись.ЗаписатьНачалоЭлемента("Период");
		Запись.ЗаписатьТекст(XMLСтрока(Движение["Период"]));
		Запись.ЗаписатьКонецЭлемента();

		Запись.ЗаписатьНачалоЭлемента("Регистратор");
		ЗаписатьСсылкуXML(Запись, Движение["Регистратор"]);
		Запись.ЗаписатьКонецЭлемента();

		Запись.ЗаписатьНачалоЭлемента("Активность");
		Запись.ЗаписатьТекст(XMLСтрока(Движение["Активность"] = Истина));
		Запись.ЗаписатьКонецЭлемента();

		Если ЭтоОстатки Тогда
			Запись.ЗаписатьНачалоЭлемента("ВидДвижения");
			Запись.ЗаписатьТекст(Строка(Движение["ВидДвижения"]));
			Запись.ЗаписатьКонецЭлемента();
		КонецЕсли;

		Для Каждого Поле Из ОписаниеПолей.Поля Цикл
			ЗаписатьПолеXML(Запись, Поле, Движение[Поле.Имя]);
		КонецЦикла;

		Запись.ЗаписатьКонецЭлемента(); // Движение
	КонецЦикла;

	Запись.ЗаписатьКонецЭлемента(); // Выгрузка
	Запись.Закрыть();

КонецПроцедуры

// Запись одного поля по правилам контракта XSD
&НаСервере
Процедура ЗаписатьПолеXML(Запись, Поле, Значение)

	// Идентификатор самой записи кодируется напрямую: <Ссылка><Тип/><Guid/></Ссылка>
	Если Поле.Имя = "Ссылка" Тогда
		ЗаписатьСсылкуXML(Запись, Значение);
		Возврат;
	КонецЕсли;

	Если Поле.Составной Тогда
		Запись.ЗаписатьНачалоЭлемента(Поле.Имя);
		Если ЭтоСсылочноеЗначение(Значение) Тогда
			ЗаписатьСсылкуXML(Запись, Значение);
		Иначе
			ЗаписатьСсылкуXML(Запись, Неопределено); // пустая <Ссылка/>
			Если Значение <> Неопределено И ЗначениеЗаполнено(Значение) Тогда
				Запись.ЗаписатьНачалоЭлемента("Значение");
				Запись.ЗаписатьТекст(ПримитивВТекстXML(Значение, Поле));
				Запись.ЗаписатьКонецЭлемента();
			КонецЕсли;
		КонецЕсли;
		Запись.ЗаписатьКонецЭлемента();
		Возврат;
	КонецЕсли;

	Если Поле.Ссылочный Тогда
		Запись.ЗаписатьНачалоЭлемента(Поле.Имя);
		ЗаписатьСсылкуXML(Запись, Значение);
		Запись.ЗаписатьКонецЭлемента();
		Возврат;
	КонецЕсли;

	// Примитив
	Если Поле.Хранилище Тогда
		Возврат; // ХранилищеЗначения не выгружаем
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Дата") И НЕ ЗначениеЗаполнено(Значение) Тогда
		Возврат; // пустая дата — элемент опускаем (xs:date/dateTime не бывает пустым)
	КонецЕсли;
	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Возврат;
	КонецЕсли;
	Запись.ЗаписатьНачалоЭлемента(Поле.Имя);
	Запись.ЗаписатьТекст(ПримитивВТекстXML(Значение, Поле));
	Запись.ЗаписатьКонецЭлемента();

КонецПроцедуры

// <Ссылка><Тип>...</Тип><Guid>...</Guid></Ссылка>;
// для пустого значения — пустая <Ссылка/> (отложенное разрешение).
&НаСервере
Процедура ЗаписатьСсылкуXML(Запись, Значение)
	Запись.ЗаписатьНачалоЭлемента("Ссылка");
	МД = МетаданныеЗначения(Значение);
	Если МД <> Неопределено И ЗначениеЗаполнено(Значение) Тогда
		Запись.ЗаписатьНачалоЭлемента("Тип");
		Запись.ЗаписатьТекст(МД.ПолноеИмя());
		Запись.ЗаписатьКонецЭлемента();
		Запись.ЗаписатьНачалоЭлемента("Guid");
		Запись.ЗаписатьТекст(ГуидЗначения(Значение));
		Запись.ЗаписатьКонецЭлемента();
	КонецЕсли;
	Запись.ЗаписатьКонецЭлемента();
КонецПроцедуры

&НаСервере
Функция ПримитивВТекстXML(Значение, Поле)
	Если ТипЗнч(Значение) = Тип("Дата") И Поле.ТолькоДата Тогда
		Возврат Формат(Значение, "ДФ=yyyy-MM-dd");
	КонецЕсли;
	Возврат XMLСтрока(Значение);
КонецФункции

// ============================================================
// ОБЩИЕ ПОМОЩНИКИ ДЛЯ ЗНАЧЕНИЙ
// ============================================================

&НаСервере
Функция МетаданныеЗначения(Значение)
	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Возврат Неопределено;
	КонецЕсли;
	Возврат Метаданные.НайтиПоТипу(ТипЗнч(Значение));
КонецФункции

&НаСервере
Функция ЭтоСсылочноеЗначение(Значение)
	Возврат МетаданныеЗначения(Значение) <> Неопределено;
КонецФункции

&НаСервере
Функция ГуидЗначения(Значение)
	Возврат Строка(Значение.УникальныйИдентификатор());
КонецФункции

&НаСервере
Функция ДобавитьРазделитель(Каталог)
	Если ПустаяСтрока(Каталог) Тогда
		Возврат Каталог;
	КонецЕсли;
	Если СтрЗаканчиваетсяНа(Каталог, "\") ИЛИ СтрЗаканчиваетсяНа(Каталог, "/") Тогда
		Возврат Каталог;
	КонецЕсли;
	Возврат Каталог + ?(СтрНайти(Каталог, "/") > 0, "/", "\");
КонецФункции

// ============================================================
// ПИСАТЕЛЬ MariaDB (контракт — schema.sql)
// Имена таблиц/колонок строятся ПО ПРАВИЛАМ generate_mariadb_schema.py:
//   "Справочник.X" -> "Справочник_X"; > 64 символов -> усечение + _md5(8);
//   составное поле -> колонки <Имя>, <Имя>_Тип [, <Имя>_Знач];
//   дубликаты имён колонок -> суффикс _2, _3...
// Используется REPLACE INTO — повторная выгрузка идемпотентна
// (PK: Ссылка у объектов, (Регистратор, НомерСтроки) у регистров).
// ============================================================

&НаСервере
Функция ИдентификаторSQL(Имя)
	Безопасное = СтрЗаменить(Имя, ".", "_");
	Если СтрДлина(Безопасное) <= 64 Тогда
		Возврат Безопасное;
	КонецЕсли;
	Возврат Лев(Безопасное, 55) + "_" + MD5Хеш8(Безопасное);
КонецФункции

&НаСервере
Функция MD5Хеш8(Стр)
	Хеширование = Новый ХешированиеДанных(ХешФункция.MD5);
	Хеширование.Добавить(ПолучитьДвоичныеДанныеИзСтроки(Стр, "UTF-8", Ложь));
	Возврат НРег(Лев(ПолучитьHexСтрокуИзДвоичныхДанных(Хеширование.ХешСумма), 8));
КонецФункции

&НаСервере
Функция ВКавычкахSQL(Идентификатор)
	Возврат "`" + СтрЗаменить(Идентификатор, "`", "``") + "`";
КонецФункции

// Список колонок для набора полей. Каждая колонка:
//   Имя  - имя колонки в таблице,
//   Поле - описание поля (см. ОписаниеПоляИзJSON),
//   Роль - "Значение" | "Тип" | "Знач" (для составных полей)
&НаСервере
Функция КолонкиДляПолей(Поля, ЗанятыеИмена)
	Колонки = Новый Массив;
	Для Каждого Поле Из Поля Цикл
		Если Поле.Составной Тогда
			ДобавитьКолонку(Колонки, ЗанятыеИмена, Поле.Имя,          Поле, "Значение");
			ДобавитьКолонку(Колонки, ЗанятыеИмена, Поле.Имя + "_Тип", Поле, "Тип");
			Если Поле.ЕстьПримитив Тогда
				ДобавитьКолонку(Колонки, ЗанятыеИмена, Поле.Имя + "_Знач", Поле, "Знач");
			КонецЕсли;
		Иначе
			ДобавитьКолонку(Колонки, ЗанятыеИмена, Поле.Имя, Поле, "Значение");
		КонецЕсли;
	КонецЦикла;
	Возврат Колонки;
КонецФункции

&НаСервере
Процедура ДобавитьКолонку(Колонки, ЗанятыеИмена, ИмяКолонки, Поле, Роль)
	// Разрешение коллизий имён — как в генераторе схемы (суффикс _2, _3...)
	Итоговое = ИмяКолонки;
	Номер = 2;
	Пока ЗанятыеИмена[ВРег(Итоговое)] <> Неопределено Цикл
		Итоговое = ИмяКолонки + "_" + Формат(Номер, "ЧГ=0");
		Номер = Номер + 1;
	КонецЦикла;
	ЗанятыеИмена.Вставить(ВРег(Итоговое), Истина);
	Колонка = Новый Структура("Имя, Поле, Роль", Итоговое, Поле, Роль);
	Колонки.Добавить(Колонка);
КонецПроцедуры

// SQL-литерал значения для колонки
&НаСервере
Функция ЗначениеКолонкиSQL(Колонка, Значение)

	Поле = Колонка.Поле;

	Если Колонка.Роль = "Тип" Тогда
		МД = МетаданныеЗначения(Значение);
		Если МД <> Неопределено И ЗначениеЗаполнено(Значение) Тогда
			Возврат РаботаСMariaDB.ЗначениеВSQL(МД.ПолноеИмя());
		ИначеЕсли Значение = Неопределено ИЛИ Значение = NULL ИЛИ НЕ ЗначениеЗаполнено(Значение) Тогда
			Возврат "NULL";
		КонецЕсли;
		Возврат РаботаСMariaDB.ЗначениеВSQL(Строка(ТипЗнч(Значение)));
	КонецЕсли;

	Если Колонка.Роль = "Знач" Тогда
		Если Значение = Неопределено ИЛИ Значение = NULL
			ИЛИ ЭтоСсылочноеЗначение(Значение) ИЛИ НЕ ЗначениеЗаполнено(Значение) Тогда
			Возврат "NULL";
		КонецЕсли;
		Возврат РаботаСMariaDB.ЗначениеВSQL(XMLСтрока(Значение)); // канонический текст примитива
	КонецЕсли;

	// Роль "Значение"
	Если Значение = Неопределено ИЛИ Значение = NULL Тогда
		Возврат "NULL";
	КонецЕсли;

	Если Поле.Составной ИЛИ Поле.Ссылочный Тогда
		Если ЭтоСсылочноеЗначение(Значение) И ЗначениеЗаполнено(Значение) Тогда
			Возврат "'" + ГуидЗначения(Значение) + "'";
		КонецЕсли;
		Возврат "NULL"; // пустая ссылка либо примитив в составном (уйдёт в _Знач)
	КонецЕсли;

	Если Поле.Хранилище Тогда
		Возврат "NULL";
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("Дата") Тогда
		Если НЕ ЗначениеЗаполнено(Значение) Тогда
			Возврат "NULL"; // пустая дата 1С вне диапазона DATETIME MariaDB
		КонецЕсли;
		Если Поле.ТолькоДата Тогда
			Возврат "'" + Формат(Значение, "ДФ=yyyy-MM-dd") + "'";
		КонецЕсли;
	КонецЕсли;
	Если ТипЗнч(Значение) = Тип("УникальныйИдентификатор") Тогда
		Возврат "'" + Строка(Значение) + "'";
	КонецЕсли;
	Возврат РаботаСMariaDB.ЗначениеВSQL(Значение);

КонецФункции

&НаСервере
Функция СобратьREPLACE(ИмяТаблицы, Колонки, СтрокиЗначений)
	ИменаКолонок = Новый Массив;
	Для Каждого Колонка Из Колонки Цикл
		ИменаКолонок.Добавить(ВКавычкахSQL(Колонка.Имя));
	КонецЦикла;
	Возврат "REPLACE INTO " + ВКавычкахSQL(ИмяТаблицы)
		+ " (" + СтрСоединить(ИменаКолонок, ", ") + ") VALUES" + Символы.ПС
		+ СтрСоединить(СтрокиЗначений, "," + Символы.ПС) + ";";
КонецФункции

&НаСервере
Процедура ВыполнитьПакетSQL(Параметры, Запросы)
	Если Запросы.Количество() = 0 Тогда
		Возврат;
	КонецЕсли;
	Результат = РаботаСMariaDB.ВыполнитьВТранзакции(Параметры.ИмяБазы, Запросы);
	Если НЕ Результат.Успех Тогда
		ВызватьИсключение Результат.Ошибка;
	КонецЕсли;
КонецПроцедуры

// --- Порция справочника/документа в MariaDB ------------------

&НаСервере
Процедура ЗаписатьПорциюСсылочногоSQL(Объект, ОписаниеПолей, Порция, ДанныеТЧ, Параметры)

	Запросы = Новый Массив;

	// Шапка
	ЗанятыеИмена = Новый Соответствие;
	Колонки = КолонкиДляПолей(ОписаниеПолей.Поля, ЗанятыеИмена);
	СтрокиЗначений = Новый Массив;
	Для Каждого ЗаписьДанных Из Порция Цикл
		СтрокиЗначений.Добавить(СтрокаЗначенийSQL(Колонки, ЗаписьДанных));
	КонецЦикла;
	Запросы.Добавить(СобратьREPLACE(ИдентификаторSQL(Объект.ПолноеИмя), Колонки, СтрокиЗначений));

	// Табличные части: отдельные таблицы <Объект>_<ТЧ> с Ссылка + НомерСтроки
	Для Каждого ТЧ Из ОписаниеПолей.ТабличныеЧасти Цикл
		ЗанятыеТЧ = Новый Соответствие;
		ЗанятыеТЧ.Вставить(ВРег("Ссылка"), Истина);
		ЗанятыеТЧ.Вставить(ВРег("НомерСтроки"), Истина);
		КолонкиТЧ = КолонкиДляПолей(ТЧ.Поля, ЗанятыеТЧ);

		СтрокиТЧSQL = Новый Массив;
		СтрокиОбъекта = ДанныеТЧ[ТЧ.Имя];
		Для Каждого ЗаписьДанных Из Порция Цикл
			СтрокиТЧ = СтрокиОбъекта[ЗаписьДанных["Ссылка"]];
			Если СтрокиТЧ = Неопределено Тогда
				Продолжить;
			КонецЕсли;
			ГуидШапки = "'" + ГуидЗначения(ЗаписьДанных["Ссылка"]) + "'";
			Для Каждого СтрокаТЧ Из СтрокиТЧ Цикл
				Значения = Новый Массив;
				Значения.Добавить(ГуидШапки);
				Значения.Добавить(Формат(СтрокаТЧ["НомерСтроки"], "ЧГ=0"));
				Для Каждого Колонка Из КолонкиТЧ Цикл
					Значения.Добавить(ЗначениеКолонкиSQL(Колонка, СтрокаТЧ[Колонка.Поле.Имя]));
				КонецЦикла;
				СтрокиТЧSQL.Добавить("(" + СтрСоединить(Значения, ", ") + ")");
			КонецЦикла;
		КонецЦикла;

		Если СтрокиТЧSQL.Количество() = 0 Тогда
			Продолжить;
		КонецЕсли;
		ВсеКолонкиТЧ = Новый Массив;
		ВсеКолонкиТЧ.Добавить(Новый Структура("Имя", "Ссылка"));
		ВсеКолонкиТЧ.Добавить(Новый Структура("Имя", "НомерСтроки"));
		Для Каждого Колонка Из КолонкиТЧ Цикл
			ВсеКолонкиТЧ.Добавить(Колонка);
		КонецЦикла;
		Запросы.Добавить(СобратьREPLACE(
			ИдентификаторSQL(Объект.ПолноеИмя + "." + ТЧ.Имя), ВсеКолонкиТЧ, СтрокиТЧSQL));
	КонецЦикла;

	ВыполнитьПакетSQL(Параметры, Запросы);

КонецПроцедуры

&НаСервере
Функция СтрокаЗначенийSQL(Колонки, ЗаписьДанных)
	Значения = Новый Массив;
	Для Каждого Колонка Из Колонки Цикл
		Значения.Добавить(ЗначениеКолонкиSQL(Колонка, ЗаписьДанных[Колонка.Поле.Имя]));
	КонецЦикла;
	Возврат "(" + СтрСоединить(Значения, ", ") + ")";
КонецФункции

// --- Порция регистра накопления в MariaDB --------------------

&НаСервере
Процедура ЗаписатьПорциюРегистраSQL(Объект, ОписаниеПолей, Порция, Параметры, ЭтоОстатки)

	ЗанятыеИмена = Новый Соответствие;
	Для Каждого Служебное Из СтрРазделить("Период,Регистратор,Регистратор_Тип,НомерСтроки,Активность,ВидДвижения", ",") Цикл
		ЗанятыеИмена.Вставить(ВРег(Служебное), Истина);
	КонецЦикла;
	Колонки = КолонкиДляПолей(ОписаниеПолей.Поля, ЗанятыеИмена);

	СтрокиЗначений = Новый Массив;
	Для Каждого Движение Из Порция Цикл
		Значения = Новый Массив;
		Значения.Добавить(РаботаСMariaDB.ЗначениеВSQL(Движение["Период"]));

		Регистратор = Движение["Регистратор"];
		МДРегистратора = МетаданныеЗначения(Регистратор);
		Если МДРегистратора <> Неопределено И ЗначениеЗаполнено(Регистратор) Тогда
			Значения.Добавить("'" + ГуидЗначения(Регистратор) + "'");
			Значения.Добавить(РаботаСMariaDB.ЗначениеВSQL(МДРегистратора.ПолноеИмя()));
		Иначе
			Значения.Добавить("NULL");
			Значения.Добавить("NULL");
		КонецЕсли;

		Значения.Добавить(Формат(Движение["НомерСтроки"], "ЧГ=0"));
		Значения.Добавить(?(Движение["Активность"] = Истина, "1", "0"));
		Если ЭтоОстатки Тогда
			// 0 = Приход, 1 = Расход (внутреннее представление 1С)
			Значения.Добавить(?(Движение["ВидДвижения"] = ВидДвиженияНакопления.Приход, "0", "1"));
		КонецЕсли;

		Для Каждого Колонка Из Колонки Цикл
			Значения.Добавить(ЗначениеКолонкиSQL(Колонка, Движение[Колонка.Поле.Имя]));
		КонецЦикла;
		СтрокиЗначений.Добавить("(" + СтрСоединить(Значения, ", ") + ")");
	КонецЦикла;

	ВсеКолонки = Новый Массив;
	ВсеКолонки.Добавить(Новый Структура("Имя", "Период"));
	ВсеКолонки.Добавить(Новый Структура("Имя", "Регистратор"));
	ВсеКолонки.Добавить(Новый Структура("Имя", "Регистратор_Тип"));
	ВсеКолонки.Добавить(Новый Структура("Имя", "НомерСтроки"));
	ВсеКолонки.Добавить(Новый Структура("Имя", "Активность"));
	Если ЭтоОстатки Тогда
		ВсеКолонки.Добавить(Новый Структура("Имя", "ВидДвижения"));
	КонецЕсли;
	Для Каждого Колонка Из Колонки Цикл
		ВсеКолонки.Добавить(Колонка);
	КонецЦикла;

	Запросы = Новый Массив;
	Запросы.Добавить(СобратьREPLACE(ИдентификаторSQL(Объект.ПолноеИмя), ВсеКолонки, СтрокиЗначений));
	ВыполнитьПакетSQL(Параметры, Запросы);

КонецПроцедуры

// ============================================================
// ЗАГРУЗКА СХЕМЫ schema.sql В MariaDB
// Файл режется на выражения по ";" в конце строки, комментарии "--"
// пропускаются. DDL в MariaDB нетранзакционен, поэтому выражения
// выполняются по одному; ошибки копятся в журнале.
// ============================================================

&НаСервере
Процедура ЗагрузитьСхемуSQLНаСервере()

	Журнал = Новый Массив;
	Журнал.Добавить("=== Загрузка схемы " + ФайлСхемыSQL + " в базу " + ИмяБазыMariaDB + " ===");

	Файл = Новый Файл(ФайлСхемыSQL);
	Если НЕ Файл.Существует() Тогда
		Журнал.Добавить("ОШИБКА: файл не найден.");
		ЗавершитьЖурнал(Журнал);
		Возврат;
	КонецЕсли;

	Выражения = РазобратьФайлSQL(ФайлСхемыSQL);
	Журнал.Добавить("Выражений к выполнению: " + Формат(Выражения.Количество(), "ЧГ=0"));

	Успешно = 0;
	Ошибок  = 0;
	Для Каждого Выражение Из Выражения Цикл
		Результат = РаботаСMariaDB.НовыйРезультат();
		РаботаСMariaDB.ВыполнитьИзменение(ИмяБазыMariaDB, Выражение, Результат);
		Если Результат.Успех Тогда
			Успешно = Успешно + 1;
		Иначе
			Ошибок = Ошибок + 1;
			Журнал.Добавить("ОШИБКА: " + Результат.Ошибка);
			Журнал.Добавить("  в выражении: " + Лев(Выражение, 200));
		КонецЕсли;
	КонецЦикла;

	Журнал.Добавить("=== Итог: успешно " + Формат(Успешно, "ЧГ=0")
		+ ", ошибок " + Формат(Ошибок, "ЧГ=0") + " ===");
	ЗавершитьЖурнал(Журнал);

КонецПроцедуры

&НаСервере
Функция РазобратьФайлSQL(ПутьКФайлу)

	Чтение = Новый ЧтениеТекста(ПутьКФайлу, КодировкаТекста.UTF8);
	Выражения = Новый Массив;
	Накоплено = "";

	Строка = Чтение.ПрочитатьСтроку();
	Пока Строка <> Неопределено Цикл
		Очищенная = СокрЛП(Строка);
		Если Очищенная <> "" И НЕ СтрНачинаетсяС(Очищенная, "--") Тогда
			Накоплено = Накоплено + ?(Накоплено = "", "", Символы.ПС) + Строка;
			Если СтрЗаканчиваетсяНа(Очищенная, ";") Тогда
				Выражения.Добавить(Накоплено);
				Накоплено = "";
			КонецЕсли;
		КонецЕсли;
		Строка = Чтение.ПрочитатьСтроку();
	КонецЦикла;
	Чтение.Закрыть();

	Если СокрЛП(Накоплено) <> "" Тогда
		Выражения.Добавить(Накоплено);
	КонецЕсли;
	Возврат Выражения;

КонецФункции
