////////////////////////////////////////////////////////////////////////////////
// Общий модуль: РаботаСMariaDB
// Назначение: работа с внешней СУБД MariaDB через ADODB (COM).
// Все экспортные методы возвращают структуру результата (см. НовыйРезультат).
//
// ВАЖНО (безопасность):
//   ADODB.Command в связке с ODBC-драйвером MariaDB здесь используется в режиме
//   adCmdText без серверных подготовленных выражений, поэтому параметры
//   подставляются в текст запроса. Для защиты от SQL-инъекций ВСЕГДА передавайте
//   значения через ЗначениеВSQL()/ЭкранироватьСтроку(), а не конкатенацией.
//   Идеальный вариант (вне рамок этого модуля) — нативные параметры ADODB
//   (cmd.Parameters), но MariaDB ODBC поддерживает их нестабильно.
////////////////////////////////////////////////////////////////////////////////

#Область ПараметрыПодключения

// Централизованные параметры подключения.
// TODO (прод): вынести в Константы/БезопасноеХранилище. Сейчас — по требованию в коде.
Функция ПараметрыСоединения()
	Парам = Новый Структура;
	Парам.Вставить("ИмяДрайвера",   "MariaDB ODBC 3.2 Driver");
	Парам.Вставить("АдресСервера",  "192.168.24.111");
	Парам.Вставить("Порт",          3306);
	Парам.Вставить("Пользователь",  "dbeaver");
	Парам.Вставить("Пароль",        "tlgknDrcnqR8");
	Парам.Вставить("Кодировка",     "utf8mb4");
	Парам.Вставить("ТаймаутПодключенияСек", 15);
	Парам.Вставить("ТаймаутКомандыСек",     60);
	Возврат Парам;
КонецФункции

Функция ВернутьСтрокуПодключения(ИмяБазы)
	П = ПараметрыСоединения();
	СтрокаПодключения = "DRIVER={" + П.ИмяДрайвера + "};"
		+ "SERVER="   + П.АдресСервера + ";"
		+ "PORT="     + Формат(П.Порт, "ЧГ=0") + ";"
		+ "DATABASE=" + ИмяБазы + ";"
		+ "USER="     + П.Пользователь + ";"
		+ "PASSWORD=" + П.Пароль + ";"
		+ "OPTION=3;"
		+ "CHARSET="  + П.Кодировка + ";";
	Возврат СтрокаПодключения;
КонецФункции

#КонецОбласти

#Область РезультатИОшибки

// Унифицированный результат любой операции.
//   Успех          - Булево
//   Ошибка         - Строка (текст ошибки или "")
//   Данные         - Произвольное (строка / ТаблицаЗначений / Массив, по методу)
//   ЗатронутоСтрок - Число (для CRUD; -1 если неизвестно)
Функция НовыйРезультат()
	Рез = Новый Структура;
	Рез.Вставить("Успех", Ложь);
	Рез.Вставить("Ошибка", "");
	Рез.Вставить("Данные", Неопределено);
	Рез.Вставить("ЗатронутоСтрок", -1);
	Возврат Рез;
КонецФункции

#КонецОбласти

#Область Экранирование

// Экранирует строку для безопасной подстановки внутри одинарных кавычек MySQL/MariaDB.
// Возвращает значение УЖЕ в кавычках: 'значение'. NULL передавайте как Неопределено.
Функция ЗначениеВSQL(Значение) Экспорт
	Если Значение = Неопределено Тогда
		Возврат "NULL";
	КонецЕсли;

	ТипЗнч = ТипЗнч(Значение);
	Если ТипЗнч = Тип("Число") Тогда
		Возврат СтрЗаменить(Формат(Значение, "ЧРД=.; ЧГ=0"), ",", ".");
	ИначеЕсли ТипЗнч = Тип("Булево") Тогда
		Возврат ?(Значение, "1", "0");
	ИначеЕсли ТипЗнч = Тип("Дата") Тогда
		Возврат "'" + Формат(Значение, "ДФ=yyyy-MM-dd HH:mm:ss") + "'";
	КонецЕсли;

	Возврат "'" + ЭкранироватьСтроку(Строка(Значение)) + "'";
КонецФункции

// Экранирует спецсимволы строки по правилам MySQL (без обрамляющих кавычек).
Функция ЭкранироватьСтроку(Стр) Экспорт
	Результат = Стр;
	Результат = СтрЗаменить(Результат, "\", "\\");
	Результат = СтрЗаменить(Результат, "'", "\'");
	Результат = СтрЗаменить(Результат, """", "\""");
	Результат = СтрЗаменить(Результат, Символ(0),  "\0");
	Результат = СтрЗаменить(Результат, Символ(10), "\n");
	Результат = СтрЗаменить(Результат, Символ(13), "\r");
	Результат = СтрЗаменить(Результат, Символ(26), "\Z");
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедуры

// Открывает соединение. Возвращает COM-объект или Неопределено (ошибку кладёт в Рез).
Функция ОткрытьСоединение(ИмяБазы, Рез)
	Попытка
		Conn = Новый COMОбъект("ADODB.Connection");
		Conn.ConnectionTimeout = ПараметрыСоединения().ТаймаутПодключенияСек;
		Conn.Open(ВернутьСтрокуПодключения(ИмяБазы));
		Возврат Conn;
	Исключение
		Рез.Успех = Ложь;
		Рез.Ошибка = "Ошибка подключения к БД """ + ИмяБазы + """: " + ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("РаботаСMariaDB.Подключение",
			УровеньЖурналаРегистрации.Ошибка, , , Рез.Ошибка);
		Возврат Неопределено;
	КонецПопытки;
КонецФункции

// Гарантированно закрывает соединение.
Процедура ЗакрытьСоединение(Conn)
	Если Conn <> Неопределено Тогда
		Попытка
			Если Conn.State <> 0 Тогда
				Conn.Close();
			КонецЕсли;
		Исключение
			// Молча: соединение уже могло быть закрыто/разорвано.
		КонецПопытки;
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ВыполнениеЗапросов

// Выполняет SELECT и возвращает результат строкой (как в исходной версии).
// Данные — строка GetString с разделителем "~". Быстро, но НЕ безопасно при "~" в данных.
//   Параметры (необязательно) — Соответствие/Структура: каждый ключ заменяется на значение
//   в тексте запроса ПЕРЕД выполнением (legacy-поведение). Используйте ЗначениеВSQL для значений!
Функция ВыполнитьЗапрос(ИмяБазы, ТекстЗапроса, Параметры = Неопределено) Экспорт

	Рез = НовыйРезультат();
	ТекстЗапроса = ПрименитьПараметры(ТекстЗапроса, Параметры);

	Conn = ОткрытьСоединение(ИмяБазы, Рез);
	Если Conn = Неопределено Тогда
		Возврат Рез;
	КонецЕсли;

	Попытка
		RS = СоздатьИВыполнить(Conn, ТекстЗапроса);
		Если RS.State = 0 ИЛИ (RS.EOF И RS.BOF) Тогда
			Рез.Данные = "";
		Иначе
			Рез.Данные = "" + RS.GetString(, , "~", Символы.ПС, "NULL");
		КонецЕсли;
		Рез.Успех = Истина;
	Исключение
		Рез.Успех = Ложь;
		Рез.Ошибка = "Ошибка выполнения запроса: " + ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("РаботаСMariaDB.Запрос",
			УровеньЖурналаРегистрации.Ошибка, , , Рез.Ошибка + Символы.ПС + ТекстЗапроса);
	КонецПопытки;

	ЗакрытьСоединение(Conn);
	Возврат Рез;
КонецФункции

// Выполняет SELECT и возвращает данные в ТаблицеЗначений (надёжный разбор через Fields).
// Рекомендуется для продакшена: корректно обрабатывает "~", переносы строк и NULL в данных.
Функция ВыполнитьЗапросТаблица(ИмяБазы, ТекстЗапроса, Параметры = Неопределено) Экспорт

	Рез = НовыйРезультат();
	ТекстЗапроса = ПрименитьПараметры(ТекстЗапроса, Параметры);

	Conn = ОткрытьСоединение(ИмяБазы, Рез);
	Если Conn = Неопределено Тогда
		Возврат Рез;
	КонецЕсли;

	Попытка
		RS = СоздатьИВыполнить(Conn, ТекстЗапроса);
		Таблица = Новый ТаблицаЗначений;

		Если RS.State <> 0 Тогда
			// Колонки
			Для Индекс = 0 По RS.Fields.Count - 1 Цикл
				Таблица.Колонки.Добавить(ИмяКолонкиБезопасное(RS.Fields(Индекс).Name, Индекс));
			КонецЦикла;
			// Строки
			Пока НЕ RS.EOF Цикл
				НоваяСтрока = Таблица.Добавить();
				Для Индекс = 0 По RS.Fields.Count - 1 Цикл
					Значение = RS.Fields(Индекс).Value;
					НоваяСтрока[Индекс] = ?(Значение = Null, Неопределено, Значение);
				КонецЦикла;
				RS.MoveNext();
			КонецЦикла;
		КонецЕсли;

		Рез.Данные = Таблица;
		Рез.Успех = Истина;
	Исключение
		Рез.Успех = Ложь;
		Рез.Ошибка = "Ошибка выполнения запроса (таблица): " + ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("РаботаСMariaDB.ЗапросТаблица",
			УровеньЖурналаРегистрации.Ошибка, , , Рез.Ошибка + Символы.ПС + ТекстЗапроса);
	КонецПопытки;

	ЗакрытьСоединение(Conn);
	Возврат Рез;
КонецФункции

// Выполняет SELECT и возвращает Массив структур (Ключ колонки -> значение).
Функция ВыполнитьЗапросМассив(ИмяБазы, ТекстЗапроса, Параметры = Неопределено) Экспорт

	РезТаблица = ВыполнитьЗапросТаблица(ИмяБазы, ТекстЗапроса, Параметры);
	Рез = НовыйРезультат();
	Рез.Успех = РезТаблица.Успех;
	Рез.Ошибка = РезТаблица.Ошибка;

	Если НЕ РезТаблица.Успех Тогда
		Возврат Рез;
	КонецЕсли;

	Таблица = РезТаблица.Данные;
	Массив = Новый Массив;
	Для Каждого СтрокаТЗ Из Таблица Цикл
		Элемент = Новый Структура;
		Для Каждого Колонка Из Таблица.Колонки Цикл
			Элемент.Вставить(Колонка.Имя, СтрокаТЗ[Колонка.Имя]);
		КонецЦикла;
		Массив.Добавить(Элемент);
	КонецЦикла;

	Рез.Данные = Массив;
	Возврат Рез;
КонецФункции

// INSERT/UPDATE/DELETE без выборки. Возвращает число затронутых строк в Рез.ЗатронутоСтрок.
Процедура ВыполнитьИзменение(ИмяБазы, ТекстЗапроса, Рез = Неопределено, Параметры = Неопределено) Экспорт

	Если Рез = Неопределено Тогда
		Рез = НовыйРезультат();
	КонецЕсли;
	ТекстЗапроса = ПрименитьПараметры(ТекстЗапроса, Параметры);

	Conn = ОткрытьСоединение(ИмяБазы, Рез);
	Если Conn = Неопределено Тогда
		Возврат;
	КонецЕсли;

	Попытка
		ЗатронутоСтрок = 0;
		// adExecuteNoRecords = 128, adCmdText = 1 -> 129. Conn.Execute заполняет RecordsAffected.
		Conn.Execute(ТекстЗапроса, ЗатронутоСтрок, 129);
		Рез.ЗатронутоСтрок = ЗатронутоСтрок;
		Рез.Успех = Истина;
	Исключение
		Рез.Успех = Ложь;
		Рез.Ошибка = "Ошибка изменения данных: " + ОписаниеОшибки();
		ЗаписьЖурналаРегистрации("РаботаСMariaDB.Изменение",
			УровеньЖурналаРегистрации.Ошибка, , , Рез.Ошибка + Символы.ПС + ТекстЗапроса);
	КонецПопытки;

	ЗакрытьСоединение(Conn);
КонецПроцедуры

#КонецОбласти

#Область Транзакции

// Выполняет массив запросов (Массив строк) в одной транзакции. Всё-или-ничего.
Функция ВыполнитьВТранзакции(ИмяБазы, МассивЗапросов) Экспорт

	Рез = НовыйРезультат();
	Conn = ОткрытьСоединение(ИмяБазы, Рез);
	Если Conn = Неопределено Тогда
		Возврат Рез;
	КонецЕсли;

	ВТранзакции = Ложь;
	Попытка
		Conn.BeginTrans();
		ВТранзакции = Истина;
		ВсегоЗатронуто = 0;
		Для Каждого Запрос Из МассивЗапросов Цикл
			ЗатронутоСтрок = 0;
			Conn.Execute(Запрос, ЗатронутоСтрок, 129);
			ВсегоЗатронуто = ВсегоЗатронуто + ЗатронутоСтрок;
		КонецЦикла;
		Conn.CommitTrans();
		ВТранзакции = Ложь;
		Рез.ЗатронутоСтрок = ВсегоЗатронуто;
		Рез.Успех = Истина;
	Исключение
		Рез.Успех = Ложь;
		Рез.Ошибка = "Ошибка транзакции (выполнен откат): " + ОписаниеОшибки();
		Если ВТранзакции Тогда
			Попытка
				Conn.RollbackTrans();
			Исключение
			КонецПопытки;
		КонецЕсли;
		ЗаписьЖурналаРегистрации("РаботаСMariaDB.Транзакция",
			УровеньЖурналаРегистрации.Ошибка, , , Рез.Ошибка);
	КонецПопытки;

	ЗакрытьСоединение(Conn);
	Возврат Рез;
КонецФункции

#КонецОбласти

#Область РазборРезультата

// Разбивает многострочную строку (результат GetString) на массив строк.
Функция РазложитьМногострочнуюСтроку(МногострочнаяСтрока) Экспорт
	Результат = Новый Массив;
	Если НЕ ЗначениеЗаполнено(МногострочнаяСтрока) Тогда
		Возврат Результат;
	КонецЕсли;
	Для ф = 1 По СтрЧислоСтрок(МногострочнаяСтрока) Цикл
		Результат.Добавить(СтрПолучитьСтроку(МногострочнаяСтрока, ф));
	КонецЦикла;
	Возврат Результат;
КонецФункции

// Разбивает строку по разделителю "~".
Функция РазложитьСтрокуРазделителями(ИсходнаяСтрока) Экспорт
	Возврат СтрРазделить(ИсходнаяСтрока, "~", Истина);
КонецФункции

#КонецОбласти

#Область Внутреннее

Функция СоздатьИВыполнить(Conn, ТекстЗапроса)
	Cmd = Новый COMОбъект("ADODB.Command");
	Cmd.ActiveConnection = Conn;
	Cmd.CommandText = ТекстЗапроса;
	Cmd.CommandType = 1; // adCmdText
	Cmd.CommandTimeout = ПараметрыСоединения().ТаймаутКомандыСек;
	Возврат Cmd.Execute();
КонецФункции

Функция ПрименитьПараметры(ТекстЗапроса, Параметры)
	Если Параметры = Неопределено Тогда
		Возврат ТекстЗапроса;
	КонецЕсли;
	Результат = ТекстЗапроса;
	Для Каждого Стр Из Параметры Цикл
		Результат = СтрЗаменить(Результат, Стр.Ключ, Стр.Значение);
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ИмяКолонкиБезопасное(ИсходноеИмя, Индекс)
	Имя = СтрЗаменить(ИсходноеИмя, " ", "_");
	Имя = СтрЗаменить(Имя, "(", "_");
	Имя = СтрЗаменить(Имя, ")", "_");
	Имя = СтрЗаменить(Имя, ".", "_");
	Если НЕ ЗначениеЗаполнено(Имя) Тогда
		Имя = "Колонка" + Формат(Индекс, "ЧГ=0");
	КонецЕсли;
	Возврат Имя;
КонецФункции

#КонецОбласти
