              <xs:element name="ТабличнаяЧасть_ТипыКонтрагента" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>Типы контрагента</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="Строка" minOccurs="0" maxOccurs="unbounded">
                      <xs:complexType>
                        <xs:sequence>
                          <xs:element name="ТипКонтрагента" minOccurs="0">
                            <xs:annotation>
                              <xs:documentation>Тип контрагента</xs:documentation>
                            </xs:annotation>
