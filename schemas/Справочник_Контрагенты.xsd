                </xs:simpleType>
              </xs:element>
              <xs:element name="ОрганизационноПравоваяФорма" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>Организационно правовая форма</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="Ссылка" type="Ссылка" />
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="ОсновноеКонтактноеЛицо" minOccurs="0">
