              </xs:element>
              <xs:element name="Страна" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>Страна</xs:documentation>
                </xs:annotation>
                <xs:complexType>
                  <xs:sequence>
                    <xs:element name="Ссылка" type="Ссылка" />
                  </xs:sequence>
                </xs:complexType>
              </xs:element>
              <xs:element name="Телефоны" minOccurs="0">
                <xs:annotation>
                  <xs:documentation>Телефоны</xs:documentation>
                </xs:annotation>
                <xs:simpleType>
                  <xs:restriction base="xs:string" />
                </xs:simpleType>
              </xs:element>
