// ============================================================
// Обработка: ВыгрузкаМетаданных
// Назначение: рекурсивный обход дерева метаданных и выгрузка
//             всех объектов, их реквизитов и типов в JSON.
// ============================================================

&НаКлиенте
Процедура ВыгрузитьМетаданныеВФайл(Команда)
    
    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
    Диалог.Заголовок = "Куда сохранить метаданные";
    Диалог.Фильтр = "JSON (*.json)|*.json";
    Диалог.Расширение = "json";
    Диалог.ПолноеИмяФайла = "metadata.json";
    
    ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораФайла", ЭтотОбъект);
    Диалог.Показать(ОписаниеОповещения);
    
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораФайла(ВыбранныеФайлы, ДопПараметры) Экспорт
    Если ВыбранныеФайлы = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    ИмяФайла = ВыбранныеФайлы[0];
    ТекстJSON = ПолучитьМетаданныеJSON();
    
    // Запись в файл через временное хранилище
    Адрес = ПоместитьТекстВХранилище(ТекстJSON);
    ПолучитьФайл(Адрес, ИмяФайла, Истина);
КонецПроцедуры

&НаСервере
Функция ПоместитьТекстВХранилище(Текст)
    ДвоичныеДанные = ПолучитьДвоичныеДанныеИзСтроки(Текст, "UTF-8", Ложь);
    Возврат ПоместитьВоВременноеХранилище(ДвоичныеДанные, УникальныйИдентификатор);
КонецФункции

// ============================================================
// СЕРВЕРНАЯ ЧАСТЬ - формирование JSON
// ============================================================

&НаСервере
Функция ПолучитьМетаданныеJSON()
    
    Результат = Новый Структура;
    Результат.Вставить("ВерсияФормата", "1.0");
    Результат.Вставить("ИмяКонфигурации", Метаданные.Имя);
    Результат.Вставить("ВерсияКонфигурации", Метаданные.Версия);
    Результат.Вставить("ДатаВыгрузки", ТекущаяДатаСеанса());
    
    Объекты = Новый Массив;
    
    // Обход всех интересующих коллекций метаданных
    ОбработатьКоллекцию(Объекты, Метаданные.Справочники,           "Справочник");
    ОбработатьКоллекцию(Объекты, Метаданные.Документы,             "Документ");
    ОбработатьКоллекцию(Объекты, Метаданные.ПланыВидовХарактеристик, "ПланВидовХарактеристик");
    ОбработатьКоллекцию(Объекты, Метаданные.ПланыСчетов,          "ПланСчетов");
    ОбработатьКоллекцию(Объекты, Метаданные.ПланыВидовРасчета,    "ПланВидовРасчета");
    ОбработатьКоллекцию(Объекты, Метаданные.ПланыОбмена,          "ПланОбмена");
    ОбработатьКоллекцию(Объекты, Метаданные.БизнесПроцессы,       "БизнесПроцесс");
    ОбработатьКоллекцию(Объекты, Метаданные.Задачи,              "Задача");
    
    // Регистры
    ОбработатьРегистрыСведений(Объекты);
    ОбработатьРегистрыНакопления(Объекты);
    ОбработатьРегистрыБухгалтерии(Объекты);
    ОбработатьРегистрыРасчета(Объекты);
    
    Результат.Вставить("Объекты", Объекты);
    
    // Сериализация в JSON
    Запись = Новый ЗаписьJSON;
    тПараметры = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, Символы.Таб);
    Запись.УстановитьСтроку(тПараметры);
    ЗаписатьJSON(Запись, Результат);
    Возврат Запись.Закрыть();
    
КонецФункции

// ------------------------------------------------------------
// Обработка ссылочных объектов (справочники, документы и т.д.)
// ------------------------------------------------------------
&НаСервере
Процедура ОбработатьКоллекцию(Объекты, Коллекция, ТипОбъекта)
    
    Для Каждого МД Из Коллекция Цикл
        
        ОписаниеОбъекта = Новый Структура;
        ОписаниеОбъекта.Вставить("Тип", ТипОбъекта);
        ОписаниеОбъекта.Вставить("Имя", МД.Имя);
        ОписаниеОбъекта.Вставить("ПолноеИмя", МД.ПолноеИмя());
        ОписаниеОбъекта.Вставить("Синоним", МД.Синоним);
        ОписаниеОбъекта.Вставить("Выгружать", Истина); // флаг для конфига выгрузки
        
        // Стандартные реквизиты (Ссылка, Код, Наименование, Дата, Номер, ПометкаУдаления...)
        ОписаниеОбъекта.Вставить("СтандартныеРеквизиты", СобратьСтандартныеРеквизиты(МД));
        
        // Реквизиты
        ОписаниеОбъекта.Вставить("Реквизиты", СобратьРеквизиты(МД));
        
        // Табличные части
        ОписаниеОбъекта.Вставить("ТабличныеЧасти", СобратьТабличныеЧасти(МД));
        
        // Спец. характеристики иерархии/владения для справочников
        Если ТипОбъекта = "Справочник" Тогда
            ДобавитьХарактеристикиСправочника(ОписаниеОбъекта, МД);
        КонецЕсли;
        
        Объекты.Добавить(ОписаниеОбъекта);
        
    КонецЦикла;
    
КонецПроцедуры

&НаСервере
Функция СобратьСтандартныеРеквизиты(МД)
    Результат = Новый Массив;
    Попытка
        Для Каждого СтандРеквизит Из МД.СтандартныеРеквизиты Цикл
            Результат.Добавить(ОписатьРеквизит(СтандРеквизит, Истина));
        КонецЦикла;
    Исключение
        // У некоторых объектов нет коллекции СтандартныеРеквизиты
    КонецПопытки;
    Возврат Результат;
КонецФункции

&НаСервере
Функция СобратьРеквизиты(МД)
    Результат = Новый Массив;
    Попытка
        Для Каждого Реквизит Из МД.Реквизиты Цикл
            Результат.Добавить(ОписатьРеквизит(Реквизит, Ложь));
        КонецЦикла;
    Исключение
    КонецПопытки;
    Возврат Результат;
КонецФункции

&НаСервере
Функция СобратьТабличныеЧасти(МД)
    Результат = Новый Массив;
    Попытка
        Для Каждого ТЧ Из МД.ТабличныеЧасти Цикл
            ОписаниеТЧ = Новый Структура;
            ОписаниеТЧ.Вставить("Имя", ТЧ.Имя);
            ОписаниеТЧ.Вставить("Синоним", ТЧ.Синоним);
            
            РеквизитыТЧ = Новый Массив;
            Для Каждого Реквизит Из ТЧ.Реквизиты Цикл
                РеквизитыТЧ.Добавить(ОписатьРеквизит(Реквизит, Ложь));
            КонецЦикла;
            ОписаниеТЧ.Вставить("Реквизиты", РеквизитыТЧ);
            
            Результат.Добавить(ОписаниеТЧ);
        КонецЦикла;
    Исключение
    КонецПопытки;
    Возврат Результат;
КонецФункции

&НаСервере
Процедура ДобавитьХарактеристикиСправочника(ОписаниеОбъекта, МД)
    ОписаниеОбъекта.Вставить("Иерархический", МД.Иерархический);
    Если МД.Иерархический Тогда
        ОписаниеОбъекта.Вставить("ВидИерархии", Строка(МД.ВидИерархии));
    КонецЕсли;
    ОписаниеОбъекта.Вставить("ИспользованиеПодчинения", Строка(МД.ИспользованиеПодчинения));
    
    Владельцы = Новый Массив;
    Для Каждого Владелец Из МД.Владельцы Цикл
        Владельцы.Добавить(Владелец.ПолноеИмя());
    КонецЦикла;
    ОписаниеОбъекта.Вставить("Владельцы", Владельцы);
КонецПроцедуры

// ------------------------------------------------------------
// Регистры
// ------------------------------------------------------------
&НаСервере
Процедура ОбработатьРегистрыСведений(Объекты)
    Для Каждого МД Из Метаданные.РегистрыСведений Цикл
        Описание = ОписаниеРегистраБазовое(МД, "РегистрСведений");
        Описание.Вставить("Измерения", СобратьИзмеренияРесурсы(МД.Измерения, "Измерение"));
        Описание.Вставить("Ресурсы",   СобратьИзмеренияРесурсы(МД.Ресурсы, "Ресурс"));
        Описание.Вставить("Реквизиты", СобратьИзмеренияРесурсы(МД.Реквизиты, "Реквизит"));
        
        Попытка
            Описание.Вставить("Периодичность", Строка(МД.Периодичность));
        Исключение
            Описание.Вставить("Периодичность", "");
        КонецПопытки;
        
        Попытка
            Описание.Вставить("РежимЗаписи", Строка(МД.РежимЗаписи));
        Исключение
            Описание.Вставить("РежимЗаписи", "");
        КонецПопытки;
        
        Объекты.Добавить(Описание);
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОбработатьРегистрыНакопления(Объекты)
    Для Каждого МД Из Метаданные.РегистрыНакопления Цикл
        Описание = ОписаниеРегистраБазовое(МД, "РегистрНакопления");
        Описание.Вставить("ВидРегистра", Строка(МД.ВидРегистра));
        Описание.Вставить("Измерения", СобратьИзмеренияРесурсы(МД.Измерения, "Измерение"));
        Описание.Вставить("Ресурсы",   СобратьИзмеренияРесурсы(МД.Ресурсы, "Ресурс"));
        Описание.Вставить("Реквизиты", СобратьИзмеренияРесурсы(МД.Реквизиты, "Реквизит"));
        Объекты.Добавить(Описание);
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОбработатьРегистрыБухгалтерии(Объекты)
    Для Каждого МД Из Метаданные.РегистрыБухгалтерии Цикл
        Описание = ОписаниеРегистраБазовое(МД, "РегистрБухгалтерии");
        Описание.Вставить("Измерения", СобратьИзмеренияРесурсы(МД.Измерения, "Измерение"));
        Описание.Вставить("Ресурсы",   СобратьИзмеренияРесурсы(МД.Ресурсы, "Ресурс"));
        Описание.Вставить("Реквизиты", СобратьИзмеренияРесурсы(МД.Реквизиты, "Реквизит"));
        Объекты.Добавить(Описание);
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОбработатьРегистрыРасчета(Объекты)
    Для Каждого МД Из Метаданные.РегистрыРасчета Цикл
        Описание = ОписаниеРегистраБазовое(МД, "РегистрРасчета");
        Описание.Вставить("Измерения", СобратьИзмеренияРесурсы(МД.Измерения, "Измерение"));
        Описание.Вставить("Ресурсы",   СобратьИзмеренияРесурсы(МД.Ресурсы, "Ресурс"));
        Описание.Вставить("Реквизиты", СобратьИзмеренияРесурсы(МД.Реквизиты, "Реквизит"));
        Объекты.Добавить(Описание);
    КонецЦикла;
КонецПроцедуры

&НаСервере
Функция ОписаниеРегистраБазовое(МД, ТипОбъекта)
    Описание = Новый Структура;
    Описание.Вставить("Тип", ТипОбъекта);
    Описание.Вставить("Имя", МД.Имя);
    Описание.Вставить("ПолноеИмя", МД.ПолноеИмя());
    Описание.Вставить("Синоним", МД.Синоним);
    Описание.Вставить("Выгружать", Истина);
    Возврат Описание;
КонецФункции

&НаСервере
Функция СобратьИзмеренияРесурсы(Коллекция, Вид)
    Результат = Новый Массив;
    Для Каждого Элемент Из Коллекция Цикл
        Поле = ОписатьРеквизит(Элемент, Ложь);
        Поле.Вставить("ВидПоля", Вид);
        Результат.Добавить(Поле);
    КонецЦикла;
    Возврат Результат;
КонецФункции

// ------------------------------------------------------------
// Универсальное описание реквизита и его типа
// ------------------------------------------------------------
&НаСервере
Функция ОписатьРеквизит(Реквизит, ЭтоСтандартный)
    
    Результат = Новый Структура;
    Результат.Вставить("Имя", Реквизит.Имя);
    
    Попытка
        Результат.Вставить("Синоним", Реквизит.Синоним);
    Исключение
        Результат.Вставить("Синоним", "");
    КонецПопытки;
    
    Результат.Вставить("Стандартный", ЭтоСтандартный);
    Результат.Вставить("Тип", ОписатьТип(Реквизит.Тип));
    
    Возврат Результат;
    
КонецФункции

// Описание ОписаниеТипов: разбор на примитивные и ссылочные типы
&НаСервере
Функция ОписатьТип(ОписаниеТиповРеквизита)
    
    Результат = Новый Структура;
    Типы = Новый Массив;
    Составной = ОписаниеТиповРеквизита.Типы().Количество() > 1;
    
    Для Каждого Тип Из ОписаниеТиповРеквизита.Типы() Цикл
        ОписаниеЭлемента = Новый Структура;
        ИмяТипа = Строка(Тип);
        ОписаниеЭлемента.Вставить("ИмяТипа", ИмяТипа);
        
        // Определяем, ссылочный ли это тип (есть метаданные)
        МетаданныеТипа = Метаданные.НайтиПоТипу(Тип);
        Если МетаданныеТипа <> Неопределено Тогда
            ОписаниеЭлемента.Вставить("Ссылочный", Истина);
            ОписаниеЭлемента.Вставить("ОбъектМетаданных", МетаданныеТипа.ПолноеИмя());
        Иначе
            ОписаниеЭлемента.Вставить("Ссылочный", Ложь);
            // Для строк/чисел добавим квалификаторы
            ДобавитьКвалификаторы(ОписаниеЭлемента, ОписаниеТиповРеквизита, Тип);
        КонецЕсли;
        
        Типы.Добавить(ОписаниеЭлемента);
    КонецЦикла;
    
    Результат.Вставить("Составной", Составной);
    Результат.Вставить("Типы", Типы);
    
    Возврат Результат;
    
КонецФункции

&НаСервере
Процедура ДобавитьКвалификаторы(ОписаниеЭлемента, ОписаниеТипов, Тип)
    
    Если Тип = Тип("Строка") Тогда
        Квал = ОписаниеТипов.КвалификаторыСтроки;
        ОписаниеЭлемента.Вставить("Длина", Квал.Длина);
        ОписаниеЭлемента.Вставить("ДопустимаяДлина", Строка(Квал.ДопустимаяДлина));
        
    ИначеЕсли Тип = Тип("Число") Тогда
        Квал = ОписаниеТипов.КвалификаторыЧисла;
        ОписаниеЭлемента.Вставить("Разрядность", Квал.Разрядность);
        ОписаниеЭлемента.Вставить("РазрядностьДробнойЧасти", Квал.РазрядностьДробнойЧасти);
        ОписаниеЭлемента.Вставить("ДопустимыйЗнак", Строка(Квал.ДопустимыйЗнак));
        
    ИначеЕсли Тип = Тип("Дата") Тогда
        Квал = ОписаниеТипов.КвалификаторыДаты;
        ОписаниеЭлемента.Вставить("ЧастиДаты", Строка(Квал.ЧастиДаты));
        
    КонецЕсли;
    
КонецПроцедуры

// ============================================================
// НОВОЕ: Этап 1 — выгрузка лёгкого каталога (только имена)
// ============================================================

&НаКлиенте
Процедура ВыгрузитьКаталогОбъектов(Команда)
    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
    Диалог.Заголовок = "Куда сохранить каталог объектов";
    Диалог.Фильтр = "JSON (*.json)|*.json";
    Диалог.Расширение = "json";
    Диалог.ПолноеИмяФайла = "catalog.json";
    
    ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораФайлаКаталога", ЭтотОбъект);
    Диалог.Показать(ОписаниеОповещения);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораФайлаКаталога(ВыбранныеФайлы, ДопПараметры) Экспорт
    Если ВыбранныеФайлы = Неопределено Тогда
        Возврат;
    КонецЕсли;
    ТекстJSON = ПолучитьКаталогJSON();
    Адрес = ПоместитьТекстВХранилище(ТекстJSON);
    ПолучитьФайл(Адрес, ВыбранныеФайлы[0], Истина);
КонецПроцедуры

&НаСервере
Функция ПолучитьКаталогJSON()
    
    Результат = Новый Структура;
    Результат.Вставить("ВерсияФормата", "1.0");
    Результат.Вставить("Назначение", "Каталог объектов. Удалите ненужные строки и используйте для полной выгрузки.");
    Результат.Вставить("ИмяКонфигурации", Метаданные.Имя);
    Результат.Вставить("ВерсияКонфигурации", Метаданные.Версия);
    Результат.Вставить("ДатаВыгрузки", ТекущаяДатаСеанса());
    
    Объекты = Новый Массив;
    
    ДобавитьИменаКоллекции(Объекты, Метаданные.Справочники,            "Справочник");
    ДобавитьИменаКоллекции(Объекты, Метаданные.Документы,              "Документ");
    ДобавитьИменаКоллекции(Объекты, Метаданные.ПланыВидовХарактеристик, "ПланВидовХарактеристик");
    ДобавитьИменаКоллекции(Объекты, Метаданные.ПланыСчетов,           "ПланСчетов");
    ДобавитьИменаКоллекции(Объекты, Метаданные.ПланыВидовРасчета,     "ПланВидовРасчета");
    ДобавитьИменаКоллекции(Объекты, Метаданные.ПланыОбмена,           "ПланОбмена");
    ДобавитьИменаКоллекции(Объекты, Метаданные.БизнесПроцессы,        "БизнесПроцесс");
    ДобавитьИменаКоллекции(Объекты, Метаданные.Задачи,               "Задача");
    ДобавитьИменаКоллекции(Объекты, Метаданные.РегистрыСведений,      "РегистрСведений");
    ДобавитьИменаКоллекции(Объекты, Метаданные.РегистрыНакопления,    "РегистрНакопления");
    ДобавитьИменаКоллекции(Объекты, Метаданные.РегистрыБухгалтерии,   "РегистрБухгалтерии");
    ДобавитьИменаКоллекции(Объекты, Метаданные.РегистрыРасчета,       "РегистрРасчета");
    
    Результат.Вставить("Объекты", Объекты);
    
    Запись = Новый ЗаписьJSON;
    тПараметры = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, Символы.Таб);
    Запись.УстановитьСтроку(тПараметры);
    ЗаписатьJSON(Запись, Результат);
    Возврат Запись.Закрыть();
    
КонецФункции

&НаСервере
Процедура ДобавитьИменаКоллекции(Объекты, Коллекция, ТипОбъекта)
    Для Каждого МД Из Коллекция Цикл
        Стр = Новый Структура;
        Стр.Вставить("Тип", ТипОбъекта);
        Стр.Вставить("Имя", МД.Имя);
        Стр.Вставить("ПолноеИмя", МД.ПолноеИмя());
        Стр.Вставить("Синоним", МД.Синоним);
        Объекты.Добавить(Стр);
    КонецЦикла;
КонецПроцедуры

// ============================================================
// НОВОЕ: Этап 2 — полная выгрузка ТОЛЬКО по каталогу
// ============================================================

&НаКлиенте
Процедура ВыгрузитьПоКаталогу(Команда)
    // Сначала выбираем входной каталог
    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Открытие);
    Диалог.Заголовок = "Выберите отредактированный каталог объектов";
    Диалог.Фильтр = "JSON (*.json)|*.json";
    
    ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораВходногоКаталога", ЭтотОбъект);
    Диалог.Показать(ОписаниеОповещения);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораВходногоКаталога(ВыбранныеФайлы, ДопПараметры) Экспорт
    Если ВыбранныеФайлы = Неопределено Тогда
        Возврат;
    КонецЕсли;
    
    // Читаем файл в строку на клиенте через помещение в хранилище
    Файл = ВыбранныеФайлы[0];
    ОписаниеЧтения = Новый ОписаниеОповещения("ПослеЗагрузкиКаталога", ЭтотОбъект);
    НачатьПомещениеФайла(ОписаниеЧтения, , Файл, Ложь, УникальныйИдентификатор);
КонецПроцедуры

&НаКлиенте
Процедура ПослеЗагрузкиКаталога(Помещён, Адрес, ВыбранноеИмя, ДопПараметры) Экспорт
    Если Не Помещён Тогда
        Возврат;
    КонецЕсли;
    
    // Формируем полную выгрузку на сервере по адресу хранилища
    АдресРезультата = ПолучитьПолнуюВыгрузкуПоКаталогу(Адрес);
    
    // Сохраняем результат
    Диалог = Новый ДиалогВыбораФайла(РежимДиалогаВыбораФайла.Сохранение);
    Диалог.Заголовок = "Куда сохранить итоговую выгрузку метаданных";
    Диалог.Фильтр = "JSON (*.json)|*.json";
    Диалог.Расширение = "json";
    Диалог.ПолноеИмяФайла = "metadata_export.json";
    
    Контекст = Новый Структура("Адрес", АдресРезультата);
    ОписаниеОповещения = Новый ОписаниеОповещения("ПослеВыбораФайлаРезультата", ЭтотОбъект, Контекст);
    Диалог.Показать(ОписаниеОповещения);
КонецПроцедуры

&НаКлиенте
Процедура ПослеВыбораФайлаРезультата(ВыбранныеФайлы, Контекст) Экспорт
    Если ВыбранныеФайлы = Неопределено Тогда
        Возврат;
    КонецЕсли;
    ПолучитьФайл(Контекст.Адрес, ВыбранныеФайлы[0], Истина);
КонецПроцедуры

&НаСервере
Функция ПолучитьПолнуюВыгрузкуПоКаталогу(АдресКаталога)
    
    // 1. Читаем каталог из хранилища
    ДвоичныеДанные = ПолучитьИзВременногоХранилища(АдресКаталога);
    Чтение = Новый ЧтениеJSON;
    Чтение.ОткрытьПоток(ДвоичныеДанные.ОткрытьПотокДляЧтения(), "UTF-8");
    КаталогСтруктура = ПрочитатьJSON(Чтение);
    Чтение.Закрыть();
    
    // 2. Строим множество разрешённых полных имён
    Разрешённые = Новый Соответствие;
    Для Каждого ЭлКаталога Из КаталогСтруктура.Объекты Цикл
        Разрешённые.Вставить(ВРег(ЭлКаталога.ПолноеИмя), Истина);
    КонецЦикла;
    
    // 3. Обычная полная выгрузка, но с фильтром по множеству
    Результат = Новый Структура;
    Результат.Вставить("ВерсияФормата", "1.0");
    Результат.Вставить("ИмяКонфигурации", Метаданные.Имя);
    Результат.Вставить("ВерсияКонфигурации", Метаданные.Версия);
    Результат.Вставить("ДатаВыгрузки", ТекущаяДатаСеанса());
    
    Объекты = Новый Массив;
    
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.Справочники,            "Справочник", Разрешённые);
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.Документы,              "Документ", Разрешённые);
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.ПланыВидовХарактеристик, "ПланВидовХарактеристик", Разрешённые);
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.ПланыСчетов,           "ПланСчетов", Разрешённые);
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.ПланыВидовРасчета,     "ПланВидовРасчета", Разрешённые);
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.ПланыОбмена,           "ПланОбмена", Разрешённые);
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.БизнесПроцессы,        "БизнесПроцесс", Разрешённые);
    ОбработатьКоллекциюСФильтром(Объекты, Метаданные.Задачи,               "Задача", Разрешённые);
    
    ОбработатьРегистрыСФильтром(Объекты, Метаданные.РегистрыСведений,    "РегистрСведений", Разрешённые);
    ОбработатьРегистрыСФильтром(Объекты, Метаданные.РегистрыНакопления,  "РегистрНакопления", Разрешённые);
    ОбработатьРегистрыСФильтром(Объекты, Метаданные.РегистрыБухгалтерии, "РегистрБухгалтерии", Разрешённые);
    ОбработатьРегистрыСФильтром(Объекты, Метаданные.РегистрыРасчета,     "РегистрРасчета", Разрешённые);
    
    Результат.Вставить("Объекты", Объекты);
    
    Запись = Новый ЗаписьJSON;
    тПараметры = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Авто, Символы.Таб);
    Запись.УстановитьСтроку(тПараметры);
    ЗаписатьJSON(Запись, Результат);
    ТекстРезультата = Запись.Закрыть();
    
    Возврат ПоместитьТекстВХранилище(ТекстРезультата);
    
КонецФункции

&НаСервере
Процедура ОбработатьКоллекциюСФильтром(Объекты, Коллекция, ТипОбъекта, Разрешённые)
    Для Каждого МД Из Коллекция Цикл
        Если Разрешённые[ВРег(МД.ПолноеИмя())] = Неопределено Тогда
            Продолжить; // объекта нет в каталоге — пропускаем
        КонецЕсли;
        
        ОписаниеОбъекта = Новый Структура;
        ОписаниеОбъекта.Вставить("Тип", ТипОбъекта);
        ОписаниеОбъекта.Вставить("Имя", МД.Имя);
        ОписаниеОбъекта.Вставить("ПолноеИмя", МД.ПолноеИмя());
        ОписаниеОбъекта.Вставить("Синоним", МД.Синоним);
        ОписаниеОбъекта.Вставить("СтандартныеРеквизиты", СобратьСтандартныеРеквизиты(МД));
        ОписаниеОбъекта.Вставить("Реквизиты", СобратьРеквизиты(МД));
        ОписаниеОбъекта.Вставить("ТабличныеЧасти", СобратьТабличныеЧасти(МД));
        
        Если ТипОбъекта = "Справочник" Тогда
            ДобавитьХарактеристикиСправочника(ОписаниеОбъекта, МД);
        КонецЕсли;
        
        Объекты.Добавить(ОписаниеОбъекта);
    КонецЦикла;
КонецПроцедуры

&НаСервере
Процедура ОбработатьРегистрыСФильтром(Объекты, Коллекция, ТипОбъекта, Разрешённые)
    Для Каждого МД Из Коллекция Цикл
        Если Разрешённые[ВРег(МД.ПолноеИмя())] = Неопределено Тогда
            Продолжить;
        КонецЕсли;
        
        Описание = ОписаниеРегистраБазовое(МД, ТипОбъекта);
        Описание.Вставить("Измерения", СобратьИзмеренияРесурсы(МД.Измерения, "Измерение"));
        Описание.Вставить("Ресурсы",   СобратьИзмеренияРесурсы(МД.Ресурсы, "Ресурс"));
        Описание.Вставить("Реквизиты", СобратьИзмеренияРесурсы(МД.Реквизиты, "Реквизит"));
        
        Если ТипОбъекта = "РегистрСведений" Тогда
            Попытка
                Описание.Вставить("Периодичность", Строка(МД.Периодичность));
            Исключение
                Описание.Вставить("Периодичность", "");
            КонецПопытки;
        ИначеЕсли ТипОбъекта = "РегистрНакопления" Тогда
            Описание.Вставить("ВидРегистра", Строка(МД.ВидРегистра));
        КонецЕсли;
        
        Объекты.Добавить(Описание);
    КонецЦикла;
КонецПроцедуры